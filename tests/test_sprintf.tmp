#include <check.h>
#include <stdio.h>
#include <string.h>
#include <limits.h>
#include <float.h>
#include "../headers/s21_string.h"
#include "./suites.h"

#define BUF_SIZE 256

START_TEST(test_percent_c) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "Char: %c", 'A');
  int ret2 = sprintf(std, "Char: %c", 'A');
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_percent_d) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "Int: %d", -12345);
  int ret2 = sprintf(std, "Int: %d", -12345);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_percent_u) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "Unsigned: %u", 4294967295U);
  int ret2 = sprintf(std, "Unsigned: %u", 4294967295U);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_percent_f) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "Float: %f", 3.1415926);
  int ret2 = sprintf(std, "Float: %f", 3.1415926);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_percent_s) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "String: %s", "hello");
  int ret2 = sprintf(std, "String: %s", "hello");
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_percent_percent) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "Percent: %%");
  int ret2 = sprintf(std, "Percent: %%");
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_flags_and_width) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "|%10d|%-10d|%+10d|% 10d|", 42, 42, 42, 42);
  int ret2 = sprintf(std, "|%10d|%-10d|%+10d|% 10d|", 42, 42, 42, 42);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_precision) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "%.2f %.5s", 2.71828, "abcdef");
  int ret2 = sprintf(std, "%.2f %.5s", 2.71828, "abcdef");
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_length_modifiers) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  short h = -1234;
  long l = 1234567890L;
  int ret1 = s21_sprintf(s21, "%hd %ld", h, l);
  int ret2 = sprintf(std, "%hd %ld", h, l);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_null_string) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "%s", NULL);
  int ret2 = sprintf(std, "%s", NULL);
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_empty_format) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "");
  int ret2 = sprintf(std, "");
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

START_TEST(test_multiple_specifiers) {
  char s21[BUF_SIZE], std[BUF_SIZE];
  int ret1 = s21_sprintf(s21, "%d %u %f %c %s %%", -1, 123U, 1.23, 'X', "abc");
  int ret2 = sprintf(std, "%d %u %f %c %s %%", -1, 123U, 1.23, 'X', "abc");
  ck_assert_str_eq(s21, std);
  ck_assert_int_eq(ret1, ret2);
}
END_TEST

Suite *s21_sprintf_suite(void) {
  Suite *s = suite_create("sprintf");
  TCase *tc_core = tcase_create("Core");

  tcase_add_test(tc_core, test_percent_c);
  tcase_add_test(tc_core, test_percent_d);
  tcase_add_test(tc_core, test_percent_u);
  tcase_add_test(tc_core, test_percent_f);
  tcase_add_test(tc_core, test_percent_s);
  tcase_add_test(tc_core, test_percent_percent);
  tcase_add_test(tc_core, test_flags_and_width);
  tcase_add_test(tc_core, test_precision);
  tcase_add_test(tc_core, test_length_modifiers);
  tcase_add_test(tc_core, test_null_string);
  tcase_add_test(tc_core, test_empty_format);
  tcase_add_test(tc_core, test_multiple_specifiers);
  
  suite_add_tcase(s, tc_core);

  return s;
} 